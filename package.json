{
  "name": "job-hunt-buddy",
  "displayName": "Job Hunt Buddy",
  "version": "0.0.1",
  "description": "A simple browser extension that helps you keep track of your job applications.",
  "author": "jafarOlamide",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "uuid": "^13.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/webextension-polyfill": "^0.12.5",
    "autoprefixer": "^10.4.27",
    "crypto-browserify": "^3.12.0",
    "postcss": "^8.5.8",
    "prettier": "3.2.4",
    "process": "^0.11.10",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "activeTab"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  },
  "overrides": {
    "@parcel/watcher": "2.1.0"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}